# 不配置 Key 时，/api/generate 会返回本地演示结果，方便验收完整交互。
IMAGE_API_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3/images/generations
IMAGE_API_KEY=
IMAGE_API_MODEL=doubao-seedream-5.0-lite
IMAGE_API_SIZE=2K

# 精细生成：Sol 负责分析全部参考图，并在 Responses API 内调用 image2。
SOL_API_BASE_URL=https://api.8989886.xyz/v1
SOL_API_KEY=
SOL_ORCHESTRATOR_MODEL=gpt-5.6-sol
# 生成任务状态和结果的临时目录；结果默认保留 24 小时。
AI_JOB_DIR=/tmp/scene-fit-ai-jobs
USER_CONTENT_DIR=/tmp/scene-fit-user-content

# User-uploaded keyframe product analysis (OpenAI-compatible endpoint)
LUNA_API_BASE_URL=https://api.8989886.xyz/v1
LUNA_API_KEY=
LUNA_API_MODEL=gpt-5.6-luna
